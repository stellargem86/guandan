# 深掼会平台后端 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========================
# 应用配置
# ========================
APP_NAME=深掼会平台
APP_VERSION=0.1.0
DEBUG=true

# ========================
# 数据库配置
# ========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shenguanhui

# ========================
# Redis 配置
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# JWT 认证配置
# ========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# 微信小程序配置
# ========================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ========================
# 微信支付配置
# ========================
WECHAT_MCH_ID=your-merchant-id
WECHAT_PAY_KEY=your-wechat-pay-api-key
WECHAT_PAY_CERT_PATH=/path/to/wechat/cert.pem
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/orders/payments/callback

# ========================
# CORS 配置
# ========================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ========================
# OSS 对象存储配置
# ========================
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=shenguanhui-assets
