# ===================================================
# 深掼会平台 - Docker Compose 环境变量配置
# 复制此文件为 .env 并填写实际值
# ===================================================

# -------------------------------------------------
# 通用配置
# -------------------------------------------------
ENVIRONMENT=development

# -------------------------------------------------
# Nginx 配置
# -------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -------------------------------------------------
# FastAPI 后端配置
# -------------------------------------------------
API_WORKERS=2

# -------------------------------------------------
# PostgreSQL 数据库
# -------------------------------------------------
POSTGRES_USER=sgh_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=shen_guan_hui
POSTGRES_PORT=5432

# -------------------------------------------------
# Redis 配置
# -------------------------------------------------
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# -------------------------------------------------
# JWT 认证配置
# -------------------------------------------------
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------
# 微信开放平台配置
# -------------------------------------------------
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# -------------------------------------------------
# 微信支付配置
# -------------------------------------------------
WECHAT_MCH_ID=your_merchant_id
WECHAT_MCH_KEY=your_merchant_api_key
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payments/callback

# -------------------------------------------------
# OSS 对象存储配置 (图片上传)
# -------------------------------------------------
OSS_ACCESS_KEY=your_oss_access_key
OSS_SECRET_KEY=your_oss_secret_key
OSS_BUCKET=sgh-uploads
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
