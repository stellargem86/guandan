{
  "enabled": true,
  "name": "Auto Git Sync",
  "description": "当项目文件被编辑保存时，自动将更改提交并推送到 GitHub",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd d:\\掼蛋 && git add -A && git diff --cached --quiet || (git commit -m \"auto: update files\" && git push origin main)"
  }
}